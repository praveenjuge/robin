{
  "name": "@workspace/convex",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "convex dev",
    "setup": "convex dev --until-success",
    "deploy": "convex deploy",
    "format": "prettier --write \"*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    "./api": {
      "types": "./_generated/api.d.ts",
      "default": "./_generated/api.js"
    },
    "./dataModel": {
      "types": "./_generated/dataModel.d.ts"
    },
    "./server": {
      "types": "./_generated/server.d.ts",
      "default": "./_generated/server.js"
    }
  },
  "dependencies": {
    "convex": "^1.41.0"
  },
  "devDependencies": {
    "@types/node": "^26",
    "@workspace/typescript-config": "workspace:*",
    "typescript": "^6"
  }
}
