# Robin environment variables
#
# Copy the relevant section into the matching .env.local file and fill in real
# values. Never commit the filled-in files; only this example is tracked.
#
# Values are placeholders. Replace each one with your own credentials.

# ---------------------------------------------------------------------------
# apps/web/.env.local  (Next.js app)
# ---------------------------------------------------------------------------

# Convex (generated by `bunx convex dev`)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Clerk auth (https://dashboard.clerk.com -> API keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Robin Eve agent endpoint + basic auth
EVE_AGENT_URL=
EVE_AGENT_USERNAME=
EVE_AGENT_PASSWORD=

# ---------------------------------------------------------------------------
# apps/agent/.env.local  (Eve agent)
# ---------------------------------------------------------------------------

# Cloudflare R2 storage (https://dash.cloudflare.com -> R2)
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Basic auth that the web app uses to reach the agent (must match web values)
EVE_AGENT_USERNAME=
EVE_AGENT_PASSWORD=

# ---------------------------------------------------------------------------
# Convex deployment env vars  (set via `bunx convex env set`, not a local file)
# ---------------------------------------------------------------------------

# Clerk JWT issuer domain used by Convex auth
# CLERK_JWT_ISSUER_DOMAIN=

# R2 access for Convex functions (mirror the apps/agent values above)
# CLOUDFLARE_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
